<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414">

    <!-- 카메라 프리뷰 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="카메라 프리뷰" />

    <!-- 상단 바 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC1C1C1E"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SafeStep"
            android:textColor="#F5F5F5"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_orange" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="감지 중"
            android:textColor="#AEAEB2"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- 위험 경고 배너 -->
    <LinearLayout
        android:id="@+id/warningBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F97316"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="14dp"
        android:visibility="gone"
        android:accessibilityLiveRegion="assertive"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/dot_white" />

        <TextView
            android:id="@+id/warningText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="앞에 사람 접근 중"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 하단 바 (마이크 버튼 영역) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC1C1C1E"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/hintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="더블탭: 상태 다시 듣기  |  마이크: 음성 명령"
            android:textColor="#6E6E73"
            android:textSize="11sp"
            android:importantForAccessibility="no" />

        <Button
            android:id="@+id/micButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="🎙"
            android:textSize="22sp"
            android:contentDescription="음성 명령 버튼. 누른 후 주변 알려줘 라고 말하세요."
            android:background="@drawable/btn_orange"
            android:padding="0dp" />

    </LinearLayout>

    <!-- 카메라 권한 거부 오버레이 -->
    <LinearLayout
        android:id="@+id/permissionDeniedView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#141414"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="16dp"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="카메라 권한이 필요합니다"
            android:textColor="#F5F5F5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeStep은 주변 장애물을 감지하기 위해\n카메라 접근 권한이 반드시 필요합니다.\n\n설정 → 앱 → SafeStep → 권한에서\n카메라를 허용해주세요."
            android:textColor="#AEAEB2"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/goToSettingsButton"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="설정으로 이동"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:contentDescription="설정으로 이동, 버튼"
            app:backgroundTint="#F97316"
            app:cornerRadius="26dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414">

    <!-- 앱 이름 -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafeStep"
        android:contentDescription="SafeStep, 시각장애인을 위한 AI 안내 앱"
        android:textColor="#F97316"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toTopOf="@id/tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- 태그라인 -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="안전한 발걸음을 위한 AI 안내"
        android:textColor="#AEAEB2"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/modeLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appName" />

    <!-- 서버 URL 레이블 -->
    <TextView
        android:id="@+id/serverUrlLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="서버 URL"
        android:textColor="#6E6E73"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tagline"
        app:layout_constraintStart_toStartOf="@id/serverUrlInput"
        app:layout_constraintEnd_toEndOf="@id/serverUrlInput" />

    <!-- 서버 URL 입력 -->
    <EditText
        android:id="@+id/serverUrlInput"
        android:layout_width="300dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:hint="http://x.x.x.x:5000/detect"
        android:textColorHint="#3A3A3C"
        android:textColor="#EEEEEE"
        android:textSize="12sp"
        android:singleLine="true"
        android:inputType="textUri"
        android:imeOptions="actionDone"
        android:background="@null"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:contentDescription="서버 URL 입력. ngrok 또는 로컬 서버 주소를 입력하세요."
        app:layout_constraintTop_toBottomOf="@id/serverUrlLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- URL 입력 구분선 -->
    <View
        android:id="@+id/serverUrlDivider"
        android:layout_width="300dp"
        android:layout_height="1dp"
        android:background="#F97316"
        android:alpha="0.5"
        app:layout_constraintTop_toBottomOf="@id/serverUrlInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 모드 선택 안내 -->
    <TextView
        android:id="@+id/modeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="모드를 선택하세요"
        android:textColor="#6E6E73"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/startButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/serverUrlDivider" />

    <!-- 카메라 모드 버튼 -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:text="📷  카메라 모드"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:contentDescription="카메라 모드. 실시간 카메라로 위험 탐지 및 내비게이션을 시작합니다."
        app:backgroundTint="#F97316"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toTopOf="@id/videoTestButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/modeLabel" />

    <!-- 동영상 테스트 버튼 -->
    <Button
        android:id="@+id/videoTestButton"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:text="🎬  동영상 테스트"
        android:textColor="#F97316"
        android:textSize="16sp"
        android:textStyle="bold"
        android:contentDescription="동영상 테스트 모드. 저장된 동영상으로 탐지를 테스트합니다."
        app:backgroundTint="#1A1A1A"
        app:strokeColor="#F97316"
        app:strokeWidth="2dp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/startButton" />

    <!-- 하단 크레딧 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="powered by AI"
        android:textColor="#3A3A3C"
        android:textSize="11sp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
